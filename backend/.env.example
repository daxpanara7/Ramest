# ---------------------------------------------------------------------------
# Ramest Technolabs backend — copy to .env and fill in. NEVER commit .env.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (Neon / Supabase / RDS).
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require
DATABASE_URL=

# App
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS + form Origin validation
CORS_ORIGINS=https://www.ramesttechnolabs.com,http://localhost:3000

# Auth — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# First admin, seeded once via `npm run seed`
ADMIN_EMAIL=hr@ramesttechnolabs.com
ADMIN_INITIAL_PASSWORD=

# Google reCAPTCHA v3 (Task 04) — create at https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
# Public site key also goes in the FRONTEND env (NEXT_PUBLIC_RECAPTCHA_SITE_KEY)
RECAPTCHA_MIN_SCORE=0.5

# Email (Task 12). Resend recommended; SMTP also supported.
RESEND_API_KEY=
MAIL_FROM="Ramest Technolabs <hr@ramesttechnolabs.com>"
MAIL_NOTIFY_TO=hr@ramesttechnolabs.com

# Media storage (Task 08). S3-compatible (AWS S3 / Cloudflare R2).
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=
